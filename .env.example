# Server-side configuration.
# These values are read by `server.js` and are not bundled into the browser.
# Copy this file to `.env.local` for local development.
# Do not commit `.env.local`.

# Required for formal generation in local and production environments.
SILICONFLOW_API_KEY="YOUR_SILICONFLOW_API_KEY"

# Optional provider settings. Current defaults already match the stable baseline.
SILICONFLOW_BASE_URL="https://api.siliconflow.cn/v1"
SILICONFLOW_MODEL="Qwen/Qwen3-32B"
SILICONFLOW_COMPACT_MODEL="Qwen/Qwen2.5-7B-Instruct"
SILICONFLOW_POLISH_MODEL="Qwen/Qwen3-32B"

# Optional grounding enhancement. Without Tavily the app can still run,
# but /api/ready may report degraded and grounding depth may be weaker.
TAVILY_API_KEY="YOUR_TAVILY_API_KEY"

# Local API port. Vercel production uses the platform runtime automatically.
PORT="8787"

# Fallback policy.
# Local development can keep this true.
# Production is recommended to set this explicitly to false.
ALLOW_PROTOTYPE_FALLBACK="true"

# Share link retention for the in-memory share store.
# Share records are not durable and will be lost after cold start or redeploy.
SHARE_TTL_MS="21600000"
SHARE_STORE_LIMIT="200"
