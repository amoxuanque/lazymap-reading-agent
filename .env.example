# Server-side model proxy configuration.
# These values are read by `server.js`, not bundled into the browser.
SILICONFLOW_API_KEY="YOUR_SILICONFLOW_API_KEY"
SILICONFLOW_MODEL="Qwen/Qwen3-32B"

# Optional: reserve for future web-search enhancement.
TAVILY_API_KEY="YOUR_TAVILY_API_KEY"

# Local API server port. Vite proxies `/api/*` to this port in dev.
PORT="8787"
